// Sapiens clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace sapiens {

    entity Account {
        id: string @unique
        holderId: string
        type: string
        balance: float
        currency: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Loan {
        id: string @unique
        borrowerId: string
        principal: float
        rate: float
        termMonths: integer
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Policy {
        id: string @unique
        holderId: string
        type: string
        premium: float
        coverage: float
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Claim {
        id: string @unique
        policyId: string
        amount: float
        status: string
        filedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Transaction {
        id: string @unique
        accountId: string
        amount: float
        type: string
        postedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Customer {
        id: string @unique
        name: string
        taxId: string
        kycStatus: string
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
